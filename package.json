{
  "name": "@pwrdrvr/microapps-app-release-workspace",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pwrdrvr/microapps-app-release.git"
  },
  "author": "PwrDrvr LLC",
  "license": "MIT",
  "homepage": "https://github.com/pwrdrvr/microapps-core#readme",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">= 22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "class-transformer": "0.5.1"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "build:jsii-release": "pnpm --filter @pwrdrvr/microapps-app-release-cdk build:jsii-release",
    "build:next": "pnpm --filter @pwrdrvr/microapps-app-release build",
    "clean": "pnpm clean:dist && pnpm clean:tsbuildinfo",
    "clean:deep": "pnpm clean:dist && pnpm clean:next && pnpm clean:modules && pnpm clean:tsbuildinfo",
    "clean:next": "npx rimraf .next",
    "clean:dist": "pnpm -r exec rimraf dist && rimraf dist",
    "clean:modules": "pnpm -r exec rimraf node_modules && rimraf node_modules",
    "clean:tsbuildinfo": "pnpm -r exec rimraf tsconfig.tsbuildinfo && rimraf tsconfig.tsbuildinfo",
    "cloc": "cloc --exclude-dir=node_modules,.storybook.next,storybook-static,cdk.out --exclude-ext=json .",
    "dev": "NODE_CONFIG_ENV=${NODE_CONFIG_ENV:-dev} DATABASE_TABLE_NAME=${DATABASE_TABLE_NAME:-microapps-dev} pnpm --filter @pwrdrvr/microapps-app-release dev",
    "lint": "pnpm exec eslint ./packages/app ./packages/cdk-stack --ext .ts --ext .tsx && pnpm --filter @pwrdrvr/microapps-app-release-cdk run eslint",
    "lint-and-fix": "pnpm exec eslint ./packages/app ./packages/cdk-stack --ext .ts --ext .tsx --fix && pnpm --filter @pwrdrvr/microapps-app-release-cdk run eslint -- --fix",
    "postinstall": "if [ -d node_modules/next ]; then patch-package --patch-dir ./patches/; else echo 'Skipping root patches'; fi",
    "start:app:next": "NODE_CONFIG_ENV=${NODE_CONFIG_ENV:-dev} DATABASE_TABLE_NAME=${DATABASE_TABLE_NAME:-microapps-dev} pnpm --filter @pwrdrvr/microapps-app-release start",
    "test:repo-tools": "node --test tests/package-manager/*.test.mjs tests/workflows/*.test.mjs scripts/*.test.mjs",
    "install:node-prune": "curl -sf https://gobinaries.com/tj/node-prune | sh"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@pwrdrvr/microapps-publish": "0.4.0-alpha.5",
    "@typescript-eslint/eslint-plugin": "^4.15.2",
    "@typescript-eslint/parser": "^4.15.2",
    "aws-cdk": "^2.1117.0",
    "eslint": "^7.20.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.23.1",
    "npm-force-resolutions": "^0.0.10",
    "patch-package": "6.5.1",
    "prettier": "^2.2.1",
    "rimraf": "4.4.0",
    "ts-node": "10.9.1",
    "typescript": "4.9.5"
  }
}
